# Railway / production environment variables (set in Railway dashboard — do not commit secrets)

# Required
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=<random-32+-char-string>
APP_URL=https://your-service.up.railway.app
DEFAULT_URI=https://your-service.up.railway.app

# From Railway MySQL plugin (reference variable)
DATABASE_URL=${{MySQL.MYSQL_URL}}

# Email (Brevo HTTPS API — Railway blocks SMTP port 587)
BREVO_API_KEY=xsmtpsib-your-brevo-api-key
# Optional override (auto-built from BREVO_API_KEY at boot if omitted):
# MAILER_DSN=brevo+api://xsmtpsib-your-brevo-api-key@default
MAILER_FROM_ADDRESS=your-verified-sender@example.com
MAILER_FROM_NAME=Lux Events

# Google OAuth (web + mobile)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Production mobile callback (update Google Cloud Console):
# GOOGLE_MOBILE_REDIRECT_URI=https://your-service.up.railway.app/api/google/mobile/callback

# JWT (keys auto-generated on first boot if missing; keep passphrase stable across redeploys)
JWT_PASSPHRASE=<strong-secret>

# CORS — add your Railway domain and mobile origins
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|10\.0\.2\.2|your-service\.up\.railway\.app)(:[0-9]+)?$'

# Optional
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
CONTACT_INBOX_EMAIL=

# --- Railway networking ---
# Public Networking target port must match container PORT (usually 8080 on Railway).
# Healthcheck path: /health.html (see railway.toml)
#
# Google Cloud Console authorized redirect URIs:
#   https://your-service.up.railway.app/connect/google/check
#   https://your-service.up.railway.app/api/google/mobile/callback  (if using mobile OAuth)
