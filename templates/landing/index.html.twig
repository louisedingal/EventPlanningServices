    <script>
        (function () {
            var v = document.querySelector('.hero-video');
            if (!v) return;
            function ensureHeroVideoPlay() {
                var p = v.play();
                if (p && typeof p.catch === 'function') {
                    p.catch(function () {});
                }
            }
            v.addEventListener('canplay', ensureHeroVideoPlay, { once: true });
            document.addEventListener('visibilitychange', function () {
                if (!document.hidden) {
                    ensureHeroVideoPlay();
                }
            });
        })();
    </script>
    <script>
        (function () {
            var top = document.querySelector('.landing-top');
            var hero = document.querySelector('.hero-section');
            if (!top || !hero) return;
            var topH = Math.ceil(top.getBoundingClientRect().height);
            var gapStr = getComputedStyle(document.documentElement).getPropertyValue('--hero-nav-gap').trim();
            var gap = Math.max(0, parseFloat(gapStr)) || 28;
            var vv = window.visualViewport && window.visualViewport.height
                ? window.visualViewport.height
                : window.innerHeight;
            hero.style.minHeight = Math.max(280, Math.round(vv - topH - gap)) + 'px';
        })();
    </script>

