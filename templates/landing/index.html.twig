        /* Hero fills real viewport below fixed bar (CSS + JS; var fallback prevents collapse) */
        :root {
            --landing-top-h: 168px;
            --hero-nav-gap: 28px;
            --hero-fill-extra: 120px;
        }
        .hero-section {
            margin-top: 0 !important;
            min-height: calc(100vh - var(--landing-top-h, 168px) + var(--hero-fill-extra, 24px)) !important;
            min-height: calc(100dvh - var(--landing-top-h, 168px) + var(--hero-fill-extra, 24px)) !important;
        }
        .hero-background,
        .hero-bg-layer {
            background-size: cover !important;
            background-position: center center !important;
        }

        .hero-video {
            position: absolute !important;
            inset: 0 !important;
            width: 100% !important;
            height: 100% !important;
            object-fit: cover !important;
            object-position: center center !important;
            z-index: 0 !important;
