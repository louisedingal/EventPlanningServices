                        </div>
                        <div class="form-group-main">
                            <label for="contact-message">Message</label>
                            <textarea id="contact-message" name="message" class="form-input-main" rows="5" placeholder="Tell us about your event..." required maxlength="5000"></textarea>
                        </div>
                        <p class="contact-form-feedback" id="contact-form-status" role="status" aria-live="polite" hidden></p>
                        <button type="submit" class="btn-contact-submit" id="contact-submit-btn">
                            <span class="btn-contact-label">Send Message</span>
                            <span class="btn-contact-loading" hidden>Sending…</span>
                        </button>
                    </form>
                    {% endif %}
                </div>
                <div class="contact-info fade-in">
                    <div class="contact-info-item">
                        <i class="bi bi-envelope-fill"></i>
                        <div>
                            <h4>Email</h4>
                            <p>L&LEvents@gmail.com</p>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <i class="bi bi-telephone-fill"></i>
                        <div>
                            <h4>Phone</h4>
                            <p>+1 (555) 123-4567</p>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <i class="bi bi-geo-alt-fill"></i>
                        <div>
                            <h4>Location</h4>
                            <p>123 Event Planning Ave, City, State 12345</p>
                        </div>
                    </div>
                    <div class="contact-social">
                        <a href="#" class="social-link" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-link" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-link" aria-label="Twitter"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="social-link" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="main-footer">
        <div class="footer-content">
            <p>&copy; {{ "now"|date("Y") }} Lux Events. All rights reserved.</p>
        </div>
    </footer>
{% endblock %}

{% block javascripts %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    <script>
        // Immediate style fix - runs before DOM is ready
        (function() {
            // Remove any admin container classes that might interfere
            if (document.documentElement) {
                document.documentElement.classList.remove('admin-page');
                document.documentElement.style.cssText = 'overflow-x: hidden !important; overflow-y: auto !important; height: auto !important;';
            }
            if (document.body) {
                document.body.classList.remove('admin-container');
                document.body.style.cssText = 'font-family: Manrope, sans-serif !important; background-color: #ffffff !important; color: #1e293b !important; margin: 0 !important; padding: 0 !important; overflow-x: hidden !important; overflow-y: auto !important; height: auto !important; min-height: 100vh !important; position: relative !important;';
            }
        })();

        // Function to fix scrolling issues
        function fixScrolling() {
            // Ensure html and body allow scrolling
            if (document.documentElement) {
                document.documentElement.style.overflowX = 'hidden';
                document.documentElement.style.overflowY = 'auto';
                document.documentElement.style.height = 'auto';
                document.documentElement.classList.remove('admin-page');
            }
            if (document.body) {
                document.body.style.overflowX = 'hidden';
                document.body.style.overflowY = 'auto';
                document.body.style.height = 'auto';
                document.body.style.minHeight = '100vh';
                document.body.style.position = 'static';
                document.body.classList.remove('admin-container');
            }
            
            // Don't override CSS sticky positioning - let CSS handle it
        }
        
        // Fix scrolling immediately
        fixScrolling();
        
        // Auto-hide flash messages and fix navigation
        document.addEventListener('DOMContentLoaded', function() {
            // Fix scrolling on DOM ready
            fixScrolling();

            // Fixed wrapper (header + nav as a single unit)
            const topEl = document.querySelector('.landing-top');
            function sizeLandingHero() {
                const hero = document.querySelector('.hero-section');
                if (!hero || !topEl) return;
                const topH = Math.ceil(topEl.getBoundingClientRect().height);
                const gapStr = getComputedStyle(document.documentElement).getPropertyValue('--hero-nav-gap').trim();
                const gap = Math.max(0, parseFloat(gapStr)) || 28;
                const vv = window.visualViewport && window.visualViewport.height
                    ? window.visualViewport.height
                    : window.innerHeight;
                hero.style.minHeight = Math.max(280, Math.round(vv - topH - gap)) + 'px';
            }
            const setTopPadding = () => {
                const topH = topEl ? Math.ceil(topEl.getBoundingClientRect().height) : 176;
                if (document.body) {
                    document.body.style.paddingTop = `${topH}px`;
                }
                document.documentElement.style.setProperty('--landing-top-h', `${topH}px`);
                sizeLandingHero();
            };
            setTopPadding();
            window.addEventListener('resize', setTopPadding);
            window.setTimeout(setTopPadding, 200);
            window.setTimeout(setTopPadding, 800);
            window.addEventListener('load', function () {
                requestAnimationFrame(function () {
                    sizeLandingHero();
                    requestAnimationFrame(sizeLandingHero);
                });
            });
            if (window.visualViewport) {
                window.visualViewport.addEventListener('resize', sizeLandingHero);
            }

            // Smooth hero background slideshow (3s per image)
            const heroLayerA = document.querySelector('.hero-bg-layer[data-hero-layer="a"]');
            const heroLayerB = document.querySelector('.hero-bg-layer[data-hero-layer="b"]');
            const heroImages = [
                // Landing hero slideshow (user-provided curated images)
                "{{ asset('img/7a42239a-ff60-4697-a65c-af925a8d9a8c.jpg') }}",
                "{{ asset('img/36c2e3ca-0b4f-4dd7-8673-3776559757f9.jpg') }}",
                "{{ asset('img/740efeff-4868-46fd-8878-ee9bd2acff58.jpg') }}",
                "{{ asset('img/754e11f3-b98a-43ab-9de0-f985a2c0b73d.jpg') }}",
                "{{ asset('img/5846b9a4-8df3-41ad-9c07-a07915a564ee.jpg') }}",
                "{{ asset('img/7363b3de-2e89-40f5-89de-31f63980d295.jpg') }}",
                "{{ asset('img/b6de7a81-a844-49fe-9a20-7582386a7a42.jpg') }}",
                "{{ asset('img/c38db778-7662-4d48-a839-074de2884384.jpg') }}",
            ];

            if (heroLayerA && heroLayerB && heroImages.length > 0) {
                let currentLayer = heroLayerA;
                let nextLayer = heroLayerB;
                let idx = 0;

                const setBg = (el, url) => {
                    el.style.backgroundImage = `url("${url}")`;
                };

                // Reset any previous timer (important when revisiting via Turbo/back cache)
                if (window.__landingHeroTimer) {
                    clearInterval(window.__landingHeroTimer);
                }

                // Initialize first visible image immediately
                setBg(currentLayer, heroImages[idx]);
                currentLayer.classList.add('is-visible');

                // Warm up cache in background, but never block transitions on loading
                heroImages.forEach((url) => {
                    const img = new Image();
                    img.src = url;
                });

                window.__landingHeroTimer = window.setInterval(() => {
                    idx = (idx + 1) % heroImages.length;
                    setBg(nextLayer, heroImages[idx]);

                    // Force reflow so opacity transition always fires
                    void nextLayer.offsetWidth;
                    nextLayer.classList.add('is-visible');
                    currentLayer.classList.remove('is-visible');

                    const tmp = currentLayer;
                    currentLayer = nextLayer;
                    nextLayer = tmp;
                }, 3500);
            }

            // Prevent selecting past dates in Preferred Date
            const preferredDateInput = document.getElementById('preferredDate');
            if (preferredDateInput && preferredDateInput.type === 'date') {
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                const yyyy = today.getFullYear();
                const mm = String(today.getMonth() + 1).padStart(2, '0');
                const dd = String(today.getDate()).padStart(2, '0');
                const minDate = `${yyyy}-${mm}-${dd}`;
                preferredDateInput.min = minDate;
                if (preferredDateInput.value && preferredDateInput.value < minDate) {
                    preferredDateInput.value = '';
                }
            }

            const contactForm = document.getElementById('contact-form-main');
            const contactSubmitBtn = document.getElementById('contact-submit-btn');
            if (contactForm && contactSubmitBtn) {
                const labelEl = contactSubmitBtn.querySelector('.btn-contact-label');
                const loadingEl = contactSubmitBtn.querySelector('.btn-contact-loading');
                contactForm.addEventListener('submit', function () {
                    contactSubmitBtn.disabled = true;
                    if (labelEl) labelEl.hidden = true;
                    if (loadingEl) loadingEl.hidden = false;
                });
            }
            
            // Get header reference for scroll detection (don't override positioning)
            const header = document.querySelector('.main-header');
            
            // Scroll to top when page loads (handles back navigation)
            window.scrollTo(0, 0);
            
            // Handle browser back/forward navigation
            window.addEventListener('pageshow', function(event) {
                // If page was loaded from cache (back/forward navigation)
                if (event.persisted) {
                    fixScrolling();
                    window.scrollTo(0, 0);
                    triggerHeroHomeAnimation();
                }
            });
            // Don't override CSS - let CSS handle header styling
            const nav = document.querySelector('.main-nav');
            const headerTopBar = document.querySelector('.header-top-bar');
            const headerTopContent = document.querySelector('.header-top-content');
            const navContainer = document.querySelector('.nav-container');
            const navLinks = document.querySelectorAll('.nav-link');
            
            if (nav) {
                // Nav/header are fixed via .landing-top; don't override nav positioning here
                nav.style.cssText = 'background: linear-gradient(135deg, #1e293b 0%, #334155 100%) !important; width: 100% !important; margin: 0 !important; padding: 1rem 2rem !important; display: block !important;';
            }
            if (headerTopBar) {
                headerTopBar.style.cssText = 'padding: 0.75rem 2rem !important; padding-left: 3rem !important; padding-right: 3rem !important; border-bottom: none !important; width: 100% !important; margin: 0 !important; box-sizing: border-box !important; display: flex !important; align-items: center !important; min-height: 84px !important;';
            }
            if (headerTopContent) {
                headerTopContent.style.cssText = 'max-width: 1400px !important; margin: 0 auto !important; display: flex !important; justify-content: space-between !important; align-items: center !important; gap: 2rem !important; width: 100% !important; box-sizing: border-box !important;';
            }
            if (navContainer) {
                // Check if user is logged in by looking for logged-in-user class or checking if certain elements exist
                const isLoggedIn = navContainer.classList.contains('logged-in-user') || 
                                   document.querySelector('.btn-get-party') !== null ||
                                   document.querySelector('.dashboard-link') !== null;
                
                const paddingRight = isLoggedIn ? '6rem' : '0';
                navContainer.style.cssText = 'max-width: 1400px !important; margin: 0 auto !important; display: flex !important; justify-content: flex-end !important; align-items: center !important; gap: 0.5rem !important; flex-wrap: wrap !important; width: 100% !important; box-sizing: border-box !important; padding-right: ' + paddingRight + ' !important;';
                
                // Ensure the logged-in-user class is applied if user is logged in
                if (isLoggedIn && !navContainer.classList.contains('logged-in-user')) {
                    navContainer.classList.add('logged-in-user');
                }
            }
            if (navLinks && navLinks.length > 0) {
                navLinks.forEach(function(link) {
                    link.style.cssText = 'color: #cbd5e1 !important; text-decoration: none !important; font-size: 0.9rem !important; font-weight: 600 !important; padding: 0.625rem 1.25rem !important; border-radius: 8px !important; display: inline-flex !important; align-items: center !important; gap: 0.5rem !important; background: transparent !important; border: none !important; cursor: pointer !important; font-family: Manrope, sans-serif !important; letter-spacing: 0.2px !important;';
                });
            }
            
            // Ensure auth buttons are perfectly aligned
            const authButtons = document.querySelector('.auth-buttons');
            if (authButtons) {
                authButtons.style.cssText = 'display: flex !important; align-items: center !important; gap: 0.75rem !important;';
            }
            
            // Professional button styles are handled by CSS - no need to override with inline styles
            
            // Ensure logo is properly sized and styled
            const logoLink = document.querySelector('.header-logo a');
            const logoImg = document.querySelector('.header-logo img');
            const logoText = document.querySelector('.logo-text');
            const headerLogo = document.querySelector('.header-logo');
            const headerRight = document.querySelector('.header-right');
            
            if (headerLogo) {
                headerLogo.style.cssText = 'display: flex !important; align-items: center !important; gap: 0.75rem !important; margin-left: -8rem !important; padding-left: 0 !important;';
            }
            if (headerRight) {
                headerRight.style.cssText = 'display: flex !important; align-items: center !important; gap: 1.5rem !important; flex-wrap: wrap !important; margin-right: -8rem !important; padding-right: 0 !important;';
            }
            if (logoLink) {
                logoLink.style.cssText = 'display: flex !important; align-items: center !important; gap: 0.75rem !important; text-decoration: none !important; color: #ffffff !important; transition: all 0.3s ease !important; padding: 0.25rem !important; border-radius: 8px !important;';
            }
            if (logoImg) {
                logoImg.style.cssText = 'height: 64px !important; width: auto !important; transition: all 0.3s ease !important; filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.4)) drop-shadow(0 0 8px rgba(255, 255, 255, 0.2)) !important; background: rgba(255, 255, 255, 0.05) !important; padding: 0.35rem !important; border-radius: 12px !important; backdrop-filter: blur(5px) !important;';
            }
            if (logoText) {
                logoText.style.cssText = 'font-family: Playfair Display, serif !important; font-size: 2.25rem !important; font-weight: 700 !important; letter-spacing: 1px !important; color: #ffffff !important; transition: all 0.3s ease !important; text-shadow: 0 3px 8px rgba(0, 0, 0, 0.4), 0 0 12px rgba(255, 255, 255, 0.15) !important;';
            }
            
            // Removed MutationObserver - let CSS handle header styling naturally

            // Auto-hide flash messages after 5s, slide out to the right (see landing.css)
            scheduleFlashDismissals();

            // Header scroll effect - header already declared above
            // Set active navigation link
            const currentPath = window.location.pathname;
            const navLinksForActiveState = document.querySelectorAll('.nav-link');
            
            navLinksForActiveState.forEach(function(link) {
                const linkPath = new URL(link.href).pathname;
                if (linkPath === currentPath || (currentPath === '/' && linkPath.includes('landing'))) {
                    link.classList.add('active');
                }
            });

            // Smooth scrolling for anchor links with fixed header+nav wrapper offset
            document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
                anchor.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
                    if (href !== '#' && href.length > 1) {
                        e.preventDefault();
                        const target = document.querySelector(href);
                        if (target) {
                            const offset = topEl ? topEl.offsetHeight : 0;
                            const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
                            window.scrollTo({
                                top: targetPosition,
                                behavior: 'smooth'
                            });
                        }
                    }
                });
            });
            
            function handleScroll() {
                const currentScroll = window.pageYOffset || document.documentElement.scrollTop;

                if (topEl) {
                    const shouldShowNavOnly = currentScroll > 60;
                    const hasNavOnly = topEl.classList.contains('nav-only');

                    if (shouldShowNavOnly !== hasNavOnly) {
                        topEl.classList.toggle('nav-only', shouldShowNavOnly);
                        // Recalculate body offset whenever header/nav visibility mode changes.
                        setTopPadding();
                    }
                }
            }
            
            // Throttle scroll event for better performance
            let ticking = false;
            window.addEventListener('scroll', function() {
                if (!ticking) {
                    window.requestAnimationFrame(function() {
                        handleScroll();
                        ticking = false;
                    });
                    ticking = true;
                }
            });
            
            // Check initial scroll position
            handleScroll();
        });
        
        // Reapply styles when page becomes visible (handles navigation from dashboard)
        document.addEventListener('visibilitychange', function() {
            if (!document.hidden) {
                fixScrolling();
                applyNavBarStyling();
                // Let CSS handle header positioning - don't override with inline styles
            }
        });
        
        // Reapply styles on window focus (handles tab switching)
        window.addEventListener('focus', function() {
            fixScrolling();
            applyNavBarStyling();
            // Let CSS handle header positioning - don't override with inline styles
        });
        
        // Function to apply navigation bar styling
        function applyNavBarStyling() {
            const navContainer = document.querySelector('.nav-container');
            if (navContainer) {
                // Check if user is logged in
                const isLoggedIn = navContainer.classList.contains('logged-in-user') || 
                                   document.querySelector('.btn-get-party') !== null ||
                                   document.querySelector('.dashboard-link') !== null ||
                                   document.querySelector('.header-center.logged-in-user') !== null;
                
                const paddingRight = isLoggedIn ? '6rem' : '0';
                navContainer.style.cssText = 'max-width: 1400px !important; margin: 0 auto !important; display: flex !important; justify-content: flex-end !important; align-items: center !important; gap: 0.5rem !important; flex-wrap: wrap !important; width: 100% !important; box-sizing: border-box !important; padding-right: ' + paddingRight + ' !important;';
                
                // Ensure the logged-in-user class is applied if user is logged in
                if (isLoggedIn) {
                    navContainer.classList.add('logged-in-user');
                } else {
                    navContainer.classList.remove('logged-in-user');
                }
            }
        }

        function triggerHeroHomeAnimation() {
            const heroSection = document.querySelector('.hero-section');
            if (!heroSection) return;
            heroSection.classList.remove('hero-animate');
            void heroSection.offsetWidth;
            heroSection.classList.add('hero-animate');
        }
        
        var FLASH_DISPLAY_MS = 5000;
        var FLASH_EXIT_ANIM_MS = 450;

        /** One 5s timer per toast; slide in/out via CSS (landing.css). Safe to call multiple times. */
        function scheduleFlashDismissals() {
            document.querySelectorAll('.flash-message:not([data-flash-scheduled])').forEach(function(message) {
                message.setAttribute('data-flash-scheduled', '1');
                setTimeout(function() {
                    message.classList.add('slide-out');
                    setTimeout(function() {
                        if (message.parentNode) {
                            message.remove();
                        }
                    }, FLASH_EXIT_ANIM_MS);
                }, FLASH_DISPLAY_MS);
            });
        }
        
        // Handle Turbo navigation events
        if (typeof Turbo !== 'undefined') {
            document.addEventListener('turbo:load', function() {
                fixScrolling();
                window.scrollTo(0, 0);
                applyNavBarStyling();
                scheduleFlashDismissals();
                triggerHeroHomeAnimation();
            });
            
            document.addEventListener('turbo:render', function() {
                fixScrolling();
                window.scrollTo(0, 0);
                applyNavBarStyling();
                scheduleFlashDismissals();
                triggerHeroHomeAnimation();
            });
            
            document.addEventListener('turbo:frame-load', function() {
                fixScrolling();
                applyNavBarStyling();
                scheduleFlashDismissals();
                triggerHeroHomeAnimation();
            });
            
            document.addEventListener('turbo:before-cache', function() {
                // Reset before navigation away
            });
        }
        
        // Ensure scroll position is reset on page load
        window.addEventListener('load', function() {
            fixScrolling();
            window.scrollTo(0, 0);
            applyNavBarStyling();
            scheduleFlashDismissals();
            triggerHeroHomeAnimation();
        });
        
        // Apply styling immediately on script execution
        applyNavBarStyling();
        
        scheduleFlashDismissals();
        triggerHeroHomeAnimation();
        
        // Fade-in Animation on Scroll
        function animateOnScroll() {
            const fadeElements = document.querySelectorAll('.fade-in');
            const windowHeight = window.innerHeight;
            
            fadeElements.forEach(function(element) {
                const elementTop = element.getBoundingClientRect().top;
                const elementVisible = 150;
                
                if (elementTop < windowHeight - elementVisible) {
                    element.classList.add('visible');
                }
            });
        }
        
        // Run animation on scroll
        window.addEventListener('scroll', animateOnScroll);
        // Run once on page load
        document.addEventListener('DOMContentLoaded', function() {
            animateOnScroll();
            // Trigger after a short delay to ensure elements are rendered
            setTimeout(animateOnScroll, 100);
        });
        
        // Also trigger on page load
        window.addEventListener('load', function() {
            setTimeout(animateOnScroll, 200);
        });

        // Keep the header time in sync with the user's local clock.
        function updateLandingHeaderTime() {
            const liveTimeElement = document.getElementById('landing-live-time');
            if (!liveTimeElement) {
                return;
            }

            const now = new Date();
            const formattedTime = now.toLocaleTimeString([], {
                hour: '2-digit',
                minute: '2-digit'
            });

            liveTimeElement.textContent = `Read, ${formattedTime} | Design`;
        }

        updateLandingHeaderTime();
        window.setInterval(updateLandingHeaderTime, 1000);
    </script>
{% endblock %}
