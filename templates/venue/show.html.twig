{% extends 'base.html.twig' %}

{% block title %}View Venue - Lux Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-container">
    {% include 'admin/_sidebar.html.twig' %}
    <main class="main-content">
        {% include 'admin/_header.html.twig' with {title: 'View Venue'} %}

        <div class="table-card">
            <div class="table-header">
                <h3>Venue Details</h3>
                <div>
                    <a href="{{ path('app_venue_index') }}" class="view-all-link">← Back to list</a>
                    <a href="{{ path('app_venue_edit', {id: venue.id}) }}" class="view-all-link" style="margin-left:12px;">Edit →</a>
                </div>
            </div>
            <div class="table-content">
                <table class="data-table">
                    <tbody>
                        <tr>
                            <th style="width:220px;">ID</th>
                            <td>#{{ venue.id }}</td>
                        </tr>
                        <tr>
                            <th>Name</th>
                            <td>{{ venue.name }}</td>
                        </tr>
                        <tr>
                            <th>Address</th>
                            <td>{{ venue.address ?: '-' }}</td>
                        </tr>
                        <tr>
                            <th>Capacity</th>
                            <td>{{ venue.capacity ?: '-' }}</td>
                        </tr>
                        <tr>
                            <th>Contact Info</th>
                            <td>{{ venue.contactInfo ?: '-' }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}















