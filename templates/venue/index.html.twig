{% extends 'base.html.twig' %}

{% block title %}Venues - Lux Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-container">
    {% include 'admin/_sidebar.html.twig' %}
    <main class="main-content">
        {% include 'admin/_header.html.twig' with {title: 'Venues'} %}

        <!-- Search Section -->
        <div class="search-filter-section">
            <form method="GET" action="{{ path('app_venue_index') }}" class="search-form">
                <div>
                    <label>Search</label>
                    <input type="text" name="q" value="{{ query }}" placeholder="Search by name, address, or contact...">
                </div>
                <div style="display: flex; gap: 0.5rem; align-items: end;">
                    <button type="submit" class="btn-primary">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <a href="{{ path('app_venue_index') }}" class="btn-secondary" style="text-decoration: none;">
                        Clear
                    </a>
                </div>
            </form>
        </div>

        <div class="table-card">
            <div class="table-header">
                <h3>All Venues</h3>
                <a href="{{ path('app_venue_new') }}" class="view-all-link">
                    New Venue <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="table-content">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Address</th>
                            <th>Capacity</th>
                            <th>Contact Info</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for venue in venues %}
                            <tr>
                                <td>#{{ venue.id }}</td>
                                <td><strong>{{ venue.name }}</strong></td>
                                <td>{{ venue.address ?: '-' }}</td>
                                <td>{{ venue.capacity ?: '-' }}</td>
                                <td>{{ venue.contactInfo ?: '-' }}</td>
                                <td>
                                    <div class="actions">
                                        <a href="{{ path('app_venue_show', {id: venue.id}) }}" class="action-btn view-btn">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        {% if isAdmin or venue.createdBy == currentUser %}
                                            <a href="{{ path('app_venue_edit', {id: venue.id}) }}" class="action-btn edit-btn">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                            <form method="post" action="{{ path('app_venue_delete', {'id': venue.id}) }}" onsubmit="return confirm('Are you sure you want to delete this venue?');" style="display: inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ venue.id) }}">
                                                <button type="submit" class="action-btn delete-btn">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="empty-state">No venues found</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}




