{% extends 'base.html.twig' %}

{% block title %}Event Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <style>
        .badge {
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }
        
        .badge-wedding {
            background-color: #fce7f3;
            color: #be185d;
        }
        
        .badge-birthday {
            background-color: #dbeafe;
            color: #1e40af;
        }
        
        .badge-corporate {
            background-color: #e0e7ff;
            color: #4338ca;
        }
        
        .badge-default {
            background-color: #f3f4f6;
            color: #374151;
        }
        
        /* Ensure action buttons display correctly on initial load */
        .actions {
            display: flex !important;
            gap: 0.5rem !important;
            align-items: center !important;
            flex-wrap: nowrap !important;
            flex-direction: row !important;
        }
        
        .actions form {
            display: inline !important;
            margin: 0 !important;
            padding: 0 !important;
        }
        
        .btn-action {
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            gap: 0.5rem !important;
            padding: 0.625rem 1rem !important;
            border-radius: 6px !important;
            font-size: 0.875rem !important;
            font-weight: 600 !important;
            text-decoration: none !important;
            border: none !important;
            cursor: pointer !important;
            height: 38px !important;
            min-height: 38px !important;
            width: 90px !important;
            min-width: 90px !important;
            max-width: 90px !important;
            box-sizing: border-box !important;
            line-height: 1 !important;
            white-space: nowrap !important;
            transition: all 0.2s ease !important;
        }
    </style>
{% endblock %}

{% block body %}
<div class="admin-container">
    {% include 'admin/_sidebar.html.twig' %}
    <main class="main-content">
        {% include 'admin/_header.html.twig' with {title: 'Event Management'} %}
    
    <!-- Search and Filter Section -->
    <div class="search-filter-section">
        <form method="GET" action="{{ path('app_event_index') }}" class="search-form">
            <div>
                <label>Search</label>
                <input type="text" name="q" value="{{ query }}" placeholder="Search by customer, theme, or venue...">
            </div>
            <div>
                <label>Event Type</label>
                <select name="type">
                    <option value="">All Types</option>
                    {% for type in eventTypes %}
                        <option value="{{ type }}" {{ selectedType == type ? 'selected' : '' }}>{{ type }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label>Venue</label>
                <select name="venue">
                    <option value="">All Venues</option>
                    {% for venue in venues %}
                        <option value="{{ venue }}" {{ selectedVenue == venue ? 'selected' : '' }}>{{ venue }}</option>
                    {% endfor %}
                </select>
            </div>
            <div style="display: flex; gap: 0.5rem; align-items: end;">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </form>
    </div>
    
    <div class="table-card">
        <div class="table-header">
            <h3>All Events</h3>
            <a href="{{ path('app_event_new') }}" class="view-all-link">
                New Event <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div class="table-content">
            <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Customer Name</th>
                    <th>Event Type</th>
                    <th>Event Date</th>
                    <th>Venue</th>
                    <th>Theme</th>
                    <th>Guests</th>
                    <th>Price</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for event in events %}
                <tr>
                    <td><strong>#{{ event.id }}</strong></td>
                    <td>{{ event.customerName }}</td>
                    <td>
                        {% set eventType = event.eventType|lower %}
                        <span class="badge badge-{{ eventType in ['wedding', 'birthday', 'corporate'] ? eventType : 'default' }}">
                            {{ event.eventType }}
                        </span>
                    </td>
                    <td>{{ event.eventDate ? event.eventDate|date('M d, Y h:i A') : '-' }}</td>
                    <td>{{ event.venue }}</td>
                    <td>{{ event.theme }}</td>
                    <td>{{ event.guestCount }}</td>
                    <td><strong>₱{{ event.price|number_format(2) }}</strong></td>
                    <td>
                        <div class="actions" style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: nowrap;">
                            <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn-action btn-show" style="display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.625rem 1rem; border-radius: 6px; font-size: 0.875rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; height: 38px; min-height: 38px; width: 90px; min-width: 90px; max-width: 90px; box-sizing: border-box; line-height: 1; white-space: nowrap; transition: all 0.2s ease; background-color: #3b82f6; color: #ffffff; box-shadow: 0 1px 2px rgba(59, 130, 246, 0.2);">
                                <i class="bi bi-eye" style="font-size: 0.875rem; display: inline-flex; align-items: center;"></i> View
                            </a>
                            {% if isAdmin or event.createdBy == currentUser %}
                                <a href="{{ path('app_event_edit', {'id': event.id}) }}" class="btn-action btn-edit" style="display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.625rem 1rem; border-radius: 6px; font-size: 0.875rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; height: 38px; min-height: 38px; width: 90px; min-width: 90px; max-width: 90px; box-sizing: border-box; line-height: 1; white-space: nowrap; transition: all 0.2s ease; background-color: #f59e0b; color: #ffffff; box-shadow: 0 1px 2px rgba(245, 158, 11, 0.2);">
                                    <i class="bi bi-pencil" style="font-size: 0.875rem; display: inline-flex; align-items: center;"></i> Edit
                                </a>
                                <form method="post" action="{{ path('app_event_delete', {'id': event.id}) }}" onsubmit="return confirm('Are you sure you want to delete this event?');" style="display: inline; margin: 0; padding: 0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                                    <button type="submit" class="btn-action delete-btn" style="display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.625rem 1rem; border-radius: 6px; font-size: 0.875rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; height: 38px; min-height: 38px; width: 90px; min-width: 90px; max-width: 90px; box-sizing: border-box; line-height: 1; white-space: nowrap; transition: all 0.2s ease; background-color: #ef4444; color: #ffffff; box-shadow: 0 1px 2px rgba(239, 68, 68, 0.2);">
                                        <i class="bi bi-trash" style="font-size: 0.875rem; display: inline-flex; align-items: center;"></i> Delete
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="9" class="empty-state">
                        <p style="font-size: 1.125rem; margin-bottom: 0.5rem;"><i class="bi bi-inbox"></i> No events found</p>
                        <p style="font-size: 0.875rem;">Create your first event to get started!</p>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
    </main>
</div>
{% endblock %}