<style>
    .delete-form {
        display: inline-block;
    }
    
    .btn-delete {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 6px rgba(239, 68, 68, 0.3);
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
    }
    
    .btn-delete:hover {
        background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(239, 68, 68, 0.4);
    }
    
    .btn-delete:active {
        transform: translateY(0);
    }
    
    .btn-delete .icon {
        margin-right: 0.5rem;
        font-size: 1rem;
    }
    
    /* Modal/Confirm Dialog Styling Enhancement */
    .delete-form.inline-delete .btn-delete {
        padding: 0.5rem 1rem;
        font-size: 0.85rem;
    }
</style>

<form method="post" action="{{ path('app_event_delete', {'id': event.id}) }}" class="delete-form" onsubmit="return confirm('⚠️ Are you sure you want to delete this event?\n\nEvent: {{ event.customerName }} - {{ event.eventType }}\nDate: {{ event.eventDate ? event.eventDate|date('M d, Y') : 'N/A' }}\n\nThis action cannot be undone!');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
    <button type="submit" class="btn-delete">
        <i class="bi bi-trash icon"></i> Delete Event
    </button>
</form>