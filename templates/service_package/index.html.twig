{% extends 'base.html.twig' %}

{% block title %}Service Packages - Lux Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-container">
    {% include 'admin/_sidebar.html.twig' %}
    <main class="main-content">
        {% include 'admin/_header.html.twig' with {title: 'Service Packages'} %}

        <!-- Search Section -->
        <div class="search-filter-section">
            <form method="GET" action="{{ path('app_service_package_index') }}" class="search-form">
                <div>
                    <label>Search</label>
                    <input type="text" name="q" value="{{ query }}" placeholder="Search by name or description...">
                </div>
                <div style="display: flex; gap: 0.5rem; align-items: end;">
                    <button type="submit" class="btn-primary">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </form>
        </div>

        <div class="table-card">
            <div class="table-header">
                <h3>All Service Packages</h3>
                <a href="{{ path('app_service_package_new') }}" class="view-all-link">
                    New Package <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="table-content">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Photo</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Price</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for service_package in service_packages %}
                            <tr>
                                <td>#{{ service_package.id }}</td>
                                <td>
                                    {% if service_package.imagePath %}
                                        <img src="{{ asset(service_package.imagePath) }}" alt="" class="package-thumb">
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td><strong>{{ service_package.name }}</strong></td>
                                <td>{{ service_package.description ?: '-' }}</td>
                                <td><strong>₱{{ service_package.price|number_format(2) }}</strong></td>
                                <td>
                                    <div class="actions">
                                        <a href="{{ path('app_service_package_show', {id: service_package.id}) }}" class="action-btn view-btn">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        {% if isAdmin or service_package.createdBy == currentUser %}
                                            <a href="{{ path('app_service_package_edit', {id: service_package.id}) }}" class="action-btn edit-btn">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                            <form method="post" action="{{ path('app_service_package_delete', {'id': service_package.id}) }}" onsubmit="return confirm('Are you sure you want to delete this service package?');" style="display: inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ service_package.id) }}">
                                                <button type="submit" class="action-btn delete-btn">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="empty-state">No service packages found</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}




