{% extends 'base.html.twig' %}

{% block title %}Themes - Lux Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-container">
    {% include 'admin/_sidebar.html.twig' %}
    <main class="main-content">
        {% include 'admin/_header.html.twig' with {title: 'Themes'} %}

        <!-- Search Section -->
        <div class="search-filter-section">
            <form method="GET" action="{{ path('app_theme_index') }}" class="search-form">
                <div>
                    <label>Search</label>
                    <input type="text" name="q" value="{{ query }}" placeholder="Search by name or description...">
                </div>
                <div>
                    <label>Event Type</label>
                    <select name="type">
                        <option value="">All Types</option>
                        <option value="Birthday" {{ currentType == 'Birthday' ? 'selected' : '' }}>Birthday</option>
                        <option value="Wedding" {{ currentType == 'Wedding' ? 'selected' : '' }}>Wedding</option>
                    </select>
                </div>
                <div style="display: flex; gap: 0.5rem; align-items: end;">
                    <button type="submit" class="btn-primary">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </form>
        </div>

        <div class="table-card">
            <div class="table-header">
                <h3>All Themes</h3>
                <a href="{{ path('app_theme_select_type') }}" class="view-all-link">
                    New Theme <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="table-content">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Type</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for theme in themes %}
                            <tr>
                                <td>#{{ theme.id }}</td>
                                <td>{{ theme.eventType ?? '-' }}</td>
                                <td>{{ theme.name }}</td>
                                <td>{{ theme.description ?: '-' }}</td>
                                <td>
                                    <div class="actions">
                                        <a href="{{ path('app_theme_show', {id: theme.id}) }}" class="action-btn view-btn">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        {% if isAdmin or theme.createdBy == currentUser %}
                                            <a href="{{ path('app_theme_edit', {id: theme.id}) }}" class="action-btn edit-btn">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                            <form method="post" action="{{ path('app_theme_delete', {'id': theme.id}) }}" onsubmit="return confirm('Are you sure you want to delete this theme?');" style="display: inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ theme.id) }}">
                                                <button type="submit" class="action-btn delete-btn">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="empty-state">No themes found</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}
