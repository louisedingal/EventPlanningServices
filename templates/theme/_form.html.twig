{{ form_start(form, {'attr': {'class': 'theme-form', 'enctype': 'multipart/form-data'}}) }}
    <div class="form-grid">
        {{ form_row(form.name, {
            row_attr: {class: 'form-row'},
            attr: {class: 'form-input', placeholder: 'e.g. Luxury & Glamour'}
        }) }}
        {{ form_row(form.description, {
            row_attr: {class: 'form-row'},
            attr: {class: 'form-textarea', placeholder: 'Describe the look and feel of this theme'}
        }) }}
        <div class="form-row form-row-full">
            {% if theme is defined and theme.sampleImagePaths|length > 0 %}
                <div class="package-image-preview theme-samples-preview">
                    <p class="form-label">Current style samples ({{ theme.sampleImagePaths|length }})</p>
                    <div class="theme-samples-grid">
                        {% for path in theme.sampleImagePaths %}
                            <img src="{{ asset(path) }}" alt="Theme sample {{ loop.index }}">
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
            {{ form_row(form.sampleImageFiles, {
                row_attr: {class: 'form-row'},
                attr: {class: 'form-input', accept: 'image/jpeg,image/png,image/webp,image/gif', multiple: 'multiple'}
            }) }}
            {% if form.removeSampleImages is defined %}
                {{ form_row(form.removeSampleImages, {row_attr: {class: 'form-row'}}) }}
            {% endif %}
        </div>
    </div>
    <div class="form-actions">
        <button class="btn-primary" type="submit">{{ submit_label|default('Save Theme') }}</button>
        <a href="{{ path('app_theme_index') }}" class="btn-secondary">Cancel</a>
    </div>
{{ form_end(form) }}
