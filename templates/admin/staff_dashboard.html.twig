{% extends 'base.html.twig' %}

{% block title %}Staff Dashboard - Lux Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="admin-container">
    <!-- Sidebar -->
    {% include 'admin/_sidebar.html.twig' %}
    
    <!-- Main Content -->
    <main class="main-content">
        {% include 'admin/_header.html.twig' with {title: 'Staff Dashboard'} %}
        
        <!-- Flash Messages -->
        {% for message in app.flashes('error') %}
            <div class="flash-message flash-error" style="position: fixed; top: 20px; right: 20px; background-color: #f8d7da; color: #721c24; padding: 15px 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); z-index: 1000; max-width: 400px; border: 1px solid #f5c6cb; animation: slideIn 0.3s ease-out;">
                <strong><i class="bi bi-exclamation-triangle"></i> Error</strong><br>
                {{ message }}
            </div>
        {% endfor %}
        
        {% for message in app.flashes('success') %}
            <div class="flash-message flash-success" style="position: fixed; top: 20px; right: 20px; background-color: #d4edda; color: #155724; padding: 15px 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); z-index: 1000; max-width: 400px; border: 1px solid #c3e6cb; animation: slideIn 0.3s ease-out;">
                <strong><i class="bi bi-check-circle"></i> Success</strong><br>
                {{ message }}
            </div>
        {% endfor %}
        
        {% set staff_display_name = (user.name|default('') ~ ' ' ~ user.lastName|default(''))|trim %}
        <!-- Welcome Card -->
        <div class="staff-welcome-card">
            <div class="staff-welcome-inner">
                <div>
                    <h2 class="staff-welcome-title">
                        Welcome back, {{ staff_display_name ? staff_display_name : user.email }}!
                    </h2>
                    <p class="staff-welcome-sub">
                        Manage your events, themes, venues, and service packages
                    </p>
                </div>
                <div class="staff-welcome-actions">
                    <a href="{{ path('app_admin_profile') }}" class="staff-welcome-btn">
                        <i class="bi bi-person"></i> My Profile
                    </a>
                    <a href="{{ path('app_admin_change_password') }}" class="staff-welcome-btn">
                        <i class="bi bi-lock"></i> Change Password
                    </a>
                </div>
            </div>
        </div>
        
        <!-- KPI Cards -->
        <div class="kpi-grid">
            <a href="{{ path('app_event_index') }}" class="kpi-card" style="text-decoration: none; cursor: pointer; transition: all 0.2s ease;">
                <div class="kpi-header">
                    <i class="bi bi-calendar-check kpi-icon"></i>
                    <span class="kpi-label">MY EVENTS</span>
                </div>
                <div class="kpi-value">{{ totalMyEvents }}</div>
            </a>
            
            <div class="kpi-card">
                <div class="kpi-header">
                    <i class="bi bi-box kpi-icon"></i>
                    <span class="kpi-label">MY RECORDS</span>
                </div>
                <div class="kpi-value">{{ totalMyRecords }}</div>
            </div>
            
            <div class="kpi-card">
                <div class="kpi-header">
                    <i class="bi bi-currency-dollar kpi-icon"></i>
                    <span class="kpi-label">MY TOTAL REVENUE</span>
                </div>
                <div class="kpi-value">₱{{ totalMyRevenue|number_format(0, '.', ',') }}</div>
            </div>
            
            <div class="kpi-card">
                <div class="kpi-header">
                    <i class="bi bi-graph-up kpi-icon"></i>
                    <span class="kpi-label">AVG EVENT PRICE</span>
                </div>
                <div class="kpi-value">₱{{ averageMyEventPrice|number_format(0, '.', ',') }}</div>
            </div>
            
            <a href="{{ path('app_theme_index') }}" class="kpi-card" style="text-decoration: none; cursor: pointer; transition: all 0.2s ease;">
                <div class="kpi-header">
                    <i class="bi bi-palette kpi-icon"></i>
                    <span class="kpi-label">MY THEMES</span>
                </div>
                <div class="kpi-value">{{ myThemes }}</div>
            </a>
            
            <a href="{{ path('app_venue_index') }}" class="kpi-card" style="text-decoration: none; cursor: pointer; transition: all 0.2s ease;">
                <div class="kpi-header">
                    <i class="bi bi-building kpi-icon"></i>
                    <span class="kpi-label">MY VENUES</span>
                </div>
                <div class="kpi-value">{{ myVenues }}</div>
            </a>
            
            <a href="{{ path('app_service_package_index') }}" class="kpi-card" style="text-decoration: none; cursor: pointer; transition: all 0.2s ease;">
                <div class="kpi-header">
                    <i class="bi bi-box-seam kpi-icon"></i>
                    <span class="kpi-label">MY PACKAGES</span>
                </div>
                <div class="kpi-value">{{ myServicePackages }}</div>
            </a>
        </div>
        
        <!-- Recent Events Table -->
        {% if recentEvents|length > 0 %}
        <div class="table-card" style="margin-top: 2rem;">
            <div class="table-header">
                <h3>Recent Events</h3>
                <a href="{{ path('app_event_index') }}" class="view-all-link">View All →</a>
            </div>
            <div class="table-content">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Customer Name</th>
                            <th>Event Type</th>
                            <th>Event Date</th>
                            <th>Price</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for event in recentEvents %}
                            <tr>
                                <td><strong>#{{ event.id }}</strong></td>
                                <td>{{ event.customerName }}</td>
                                <td>
                                    <span class="event-type-badge event-type-{{ event.eventType|lower }}">
                                        {{ event.eventType }}
                                    </span>
                                </td>
                                <td>{{ event.eventDate ? event.eventDate|date('M d, Y h:i A') : '-' }}</td>
                                <td><strong>₱{{ event.price|number_format(2) }}</strong></td>
                                <td>
                                    <div class="actions">
                                        <a href="{{ path('app_event_show', {'id': event.id}) }}" class="action-btn view-btn">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        {% if isAdmin or event.createdBy == currentUser %}
                                            <a href="{{ path('app_event_edit', {'id': event.id}) }}" class="action-btn edit-btn">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}
        
        <!-- Pending Event Requests Section -->
        <div id="event-requests-section" class="table-card" style="margin-top: 2rem;">
            <div class="table-header">
                <h3 class="js-pending-requests-heading">Pending Event Requests ({{ totalPendingRequests }})</h3>
            </div>
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Source</th>
                            <th>Client</th>
                            <th>Event Type</th>
                            <th>Preferred Date</th>
                            <th>Guest Count</th>
                            <th>Budget</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody class="js-pending-requests-tbody" data-show-view="0">
                        {% if pendingEventRequests|length > 0 %}
                            {% for request in pendingEventRequests %}
                                <tr data-request-id="{{ request.id }}">
                                    <td>{{ request.createdAt|date('Y-m-d H:i') }}</td>
                                    <td>{% include 'admin/_event_request_source_badge.html.twig' with { request: request } %}</td>
                                    <td><strong>{{ request.requestedBy ? request.requestedBy.email : 'Deleted user' }}</strong></td>
                                    <td>{{ request.eventType }}</td>
                                    <td>{{ request.preferredDate ? request.preferredDate|date('Y-m-d') : '-' }}</td>
                                    <td>{{ request.estimatedGuestCount ?? '-' }}</td>
                                    <td>{{ request.budget ?? '-' }}</td>
                                    <td>
                                        <span class="status-badge pending" style="padding: 0.35rem 0.75rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; background: #fef3c7; color: #92400e; text-transform: uppercase;">
                                            {{ request.status }}
                                        </span>
                                    </td>
                                    <td>
                                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                                            <form method="post" action="{{ path('app_admin_event_request_mark_done', {'id': request.id}) }}" style="display: inline-block; margin: 0;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('mark_done_' ~ request.id) }}">
                                                <button type="submit" class="action-btn" style="padding: 0.5rem 1rem; background: #10b981; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; transition: all 0.2s ease;" onmouseover="this.style.background='#059669'" onmouseout="this.style.background='#10b981'">
                                                    <i class="bi bi-check-circle"></i> Done
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="9" class="empty-state">
                                    <p>No pending event requests</p>
                                </td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>

    </main>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <style>
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        
        @keyframes slideOut {
            from {
                transform: translateX(0);
                opacity: 1;
            }
            to {
                transform: translateX(100%);
                opacity: 0;
            }
        }
        
        .flash-message {
            animation: slideIn 0.3s ease-out;
        }
        
        .flash-message.fade-out {
            animation: slideOut 0.3s ease-out;
        }
        
        .quick-action-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.2) !important;
        }
    </style>
    <script>
        // Auto-hide flash messages after 5 seconds
        document.addEventListener('DOMContentLoaded', function() {
            const flashMessages = document.querySelectorAll('.flash-message');
            flashMessages.forEach(function(message) {
                setTimeout(function() {
                    message.classList.add('fade-out');
                    setTimeout(function() {
                        message.remove();
                    }, 300);
                }, 5000);
            });
        });
    </script>
{% endblock %}

