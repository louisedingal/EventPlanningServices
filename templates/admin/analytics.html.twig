{% extends 'base.html.twig' %}

{% block title %}Analytics - Lux Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="admin-container">
    <!-- Sidebar -->
    {% include 'admin/_sidebar.html.twig' %}
    
    <!-- Main Content -->
    <main class="main-content">
        {% include 'admin/_header.html.twig' with {title: 'Analytics & Reports'} %}
        {% set totalRevenue = revenueByType|reduce((carry, v) => carry + v, 0) %}
        
        <!-- Analytics Cards -->
        <div class="kpi-grid">
            <div class="kpi-card">
                <div class="kpi-header">
                    <span class="kpi-icon">📊</span>
                    <span class="kpi-label">Total Events</span>
                </div>
                <div class="kpi-value">{{ totalEvents }}</div>
            </div>
            
            <div class="kpi-card">
                <div class="kpi-header">
                    <span class="kpi-icon">💰</span>
                    <span class="kpi-label">Total Revenue</span>
                </div>
                <div class="kpi-value">₱{{ totalRevenue|number_format(0, '.', ',') }}</div>
            </div>
            
            <div class="kpi-card">
                <div class="kpi-header">
                    <span class="kpi-icon">📈</span>
                    <span class="kpi-label">Avg Revenue/Event</span>
                </div>
                <div class="kpi-value">₱{{ (totalEvents ? (totalRevenue / totalEvents) : 0)|number_format(0, '.', ',') }}</div>
            </div>
            
            <div class="kpi-card">
                <div class="kpi-header">
                    <span class="kpi-icon">🏆</span>
                    <span class="kpi-label">Top Event Type</span>
                </div>
                <div class="kpi-value">
                    {% set topType = eventsByType|keys|first %}
                    {{ topType }}
                </div>
            </div>
        </div>
        
        <!-- Analytics Charts -->
        <div class="charts-grid">
            <!-- Revenue by Event Type -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3>Revenue by Event Type</h3>
                    <div class="chart-controls">
                        <select class="chart-select">
                            <option>All Time</option>
                            <option>This Year</option>
                            <option>This Month</option>
                        </select>
                    </div>
                </div>
                <div class="chart-content">
                    <div class="chart-legend">
                        {% for type, revenue in revenueByType %}
                            <div class="legend-item">
                                <span class="legend-color" style="background-color: {{ cycle(['#FFD700', '#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'], loop.index0) }}"></span>
                                <span class="legend-label">{{ type }} (₱{{ revenue|number_format(0, '.', ',') }})</span>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="chart-bars">
                        {% set maxRevenue = revenueByType|reduce((carry, v) => v > carry ? v : carry, 0) %}
                        {% for type, revenue in revenueByType %}
                            <div class="chart-bar">
                                <div class="bar-fill" 
                                     style="height: {{ (revenue / (maxRevenue ? maxRevenue : 1) * 100)|round }}%; 
                                            background-color: {{ cycle(['#FFD700', '#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'], loop.index0) }};">
                                </div>
                                <span class="bar-label">₱{{ revenue|number_format(0, '.', ',') }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            
            <!-- Events by Venue -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3>Events by Venue</h3>
                    <div class="chart-controls">
                        <select class="chart-select">
                            <option>Top 10</option>
                            <option>All Venues</option>
                        </select>
                    </div>
                </div>
                <div class="chart-content">
                    {% set maxEventsByVenue = eventsByVenue|reduce((carry, v) => v > carry ? v : carry, 0) %}
                    <div class="venue-list">
                        {% for venue, count in eventsByVenue|slice(0, 10) %}
                            <div class="venue-item">
                                <div class="venue-info">
                                    <span class="venue-name">{{ venue }}</span>
                                    <span class="venue-count">{{ count }} events</span>
                                </div>
                                <div class="venue-bar">
                                    <div class="venue-fill" style="width: {{ (count / (maxEventsByVenue ? maxEventsByVenue : 1) * 100)|round }}%;"></div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Detailed Analytics Table -->
        <div class="table-card">
            <div class="table-header">
                <h3>Event Type Analysis</h3>
                <div class="table-filters">
                    <select class="filter-select">
                        <option>All Types</option>
                        {% for type in eventsByType|keys %}
                            <option>{{ type }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="table-content">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Event Type</th>
                            <th>Total Events</th>
                            <th>Total Revenue</th>
                            <th>Avg Revenue</th>
                            <th>Market Share</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for type, count in eventsByType %}
                            <tr>
                                <td>
                                    <span class="event-type-badge event-type-{{ type|lower }}">
                                        {{ type }}
                                    </span>
                                </td>
                                <td><strong>{{ count }}</strong></td>
                                <td><strong>₱{{ revenueByType[type]|number_format(2) }}</strong></td>
                                <td>₱{{ (revenueByType[type] / count)|number_format(2) }}</td>
                                <td>
                                    <div class="market-share">
                                        <div class="market-share-bar">
                                            <div class="market-share-fill" style="width: {{ (count / totalEvents * 100)|round }}%;"></div>
                                        </div>
                                        <span class="market-share-text">{{ (count / totalEvents * 100)|round }}%</span>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<style>
.venue-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 200px;
    overflow-y: auto;
}

.venue-item {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.venue-info {
    display: flex;
    flex-direction: column;
    min-width: 150px;
}

.venue-name {
    font-weight: 500;
    color: #1e293b;
    font-size: 0.875rem;
}

.venue-count {
    font-size: 0.75rem;
    color: #64748b;
}

.venue-bar {
    flex: 1;
    height: 8px;
    background-color: #f1f5f9;
    border-radius: 4px;
    overflow: hidden;
}

.venue-fill {
    height: 100%;
    background-color: #fbbf24;
    border-radius: 4px;
    transition: width 0.3s ease;
}

.market-share {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.market-share-bar {
    flex: 1;
    height: 6px;
    background-color: #f1f5f9;
    border-radius: 3px;
    overflow: hidden;
}

.market-share-fill {
    height: 100%;
    background-color: #fbbf24;
    border-radius: 3px;
    transition: width 0.3s ease;
}

.market-share-text {
    font-size: 0.75rem;
    font-weight: 600;
    color: #64748b;
    min-width: 35px;
}
</style>
{% endblock %}
