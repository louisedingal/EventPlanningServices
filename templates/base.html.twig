<!DOCTYPE html>
<html lang="en" data-turbo="false">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        <style>
            @keyframes globalFlashEnterRight {
                from { transform: translateX(calc(100% + 24px)); opacity: 0; }
                to { transform: translateX(0); opacity: 1; }
            }
            @keyframes globalFlashExitRight {
                from { transform: translateX(0); opacity: 1; }
                to { transform: translateX(calc(100% + 24px)); opacity: 0; }
            }
            .flash-message.global-flash-animated {
                animation: globalFlashEnterRight 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
                will-change: transform, opacity;
            }
            .flash-message.global-slide-out {
                animation: globalFlashExitRight 0.45s cubic-bezier(0.4, 0, 1, 1) forwards !important;
            }
        </style>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script>
                (function () {
                    var FLASH_DISPLAY_MS = 5000;
                    var FLASH_EXIT_MS = 450;

                    function scheduleGlobalFlashDismissals() {
                        var messages = document.querySelectorAll('.flash-message:not([data-global-flash-scheduled])');
                        messages.forEach(function (message) {
                            message.setAttribute('data-global-flash-scheduled', '1');
                            message.classList.add('global-flash-animated');
                            setTimeout(function () {
                                message.classList.add('global-slide-out');
                                setTimeout(function () {
                                    if (message.parentNode) {
                                        message.remove();
                                    }
                                }, FLASH_EXIT_MS);
                            }, FLASH_DISPLAY_MS);
                        });
                    }

                    document.addEventListener('DOMContentLoaded', scheduleGlobalFlashDismissals);
                    window.addEventListener('load', scheduleGlobalFlashDismissals);
                    document.addEventListener('turbo:load', scheduleGlobalFlashDismissals);
                    document.addEventListener('turbo:render', scheduleGlobalFlashDismissals);
                    scheduleGlobalFlashDismissals();
                })();
            </script>
        {% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>
