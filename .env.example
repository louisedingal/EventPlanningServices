###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_a_random_32_char_string
###< symfony/framework-bundle ###

# Public URL for absolute links (email verification, Google OAuth). Railway sets this from RAILWAY_PUBLIC_DOMAIN if omitted.
APP_URL=http://127.0.0.1:8000

###> symfony/routing ###
DEFAULT_URI=http://127.0.0.1:8000
###< symfony/routing ###

APP_PORT=8000
# Internal realtime websocket worker (proxied by nginx via /ws/notifications)
REALTIME_WS_ENABLED=1
REALTIME_WS_PORT=8081
REALTIME_WS_INTERVAL=2

# MySQL (docker-compose)
MYSQL_ROOT_PASSWORD=eventplanner_root_password
MYSQL_DATABASE=eventplanner_db
MYSQL_USER=eventplanner_user
MYSQL_PASSWORD=eventplanner_password

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://eventplanner_user:eventplanner_password@127.0.0.1:3307/eventplanner_db?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer (local dev — SMTP) ###
BREVO_SMTP_USER=your-login@smtp-brevo.com
BREVO_SMTP_KEY=xsmtpsib-your-brevo-smtp-key
# Railway production: BREVO_API_KEY (same xsmtpsib-... key from Brevo dashboard)
BREVO_API_KEY=
# Prod only; leave empty locally (entrypoint sets brevo+api://… from BREVO_API_KEY on Railway)
MAILER_DSN=
MAILER_FROM_ADDRESS=your-verified-sender@example.com
MAILER_FROM_NAME="Lux Events"
###< symfony/mailer ###

###> google/oauth ###
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Mobile OAuth — add this exact URI in Google Cloud Console (http://127.0.0.1 for emulator)
GOOGLE_MOBILE_REDIRECT_URI=http://127.0.0.1:8000/api/google/mobile/callback
###< google/oauth ###

CONTACT_INBOX_EMAIL=
# Optional: third-party contact form iframe URL (empty = built-in Symfony form)
CONTACT_FORM_EMBED_URL=

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|10\.0\.2\.2)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase
###< lexik/jwt-authentication-bundle ###
